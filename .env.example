# PostgreSQL
POSTGRES_DB=reconciliation
POSTGRES_USER=recon
POSTGRES_PASSWORD=recon_secret
POSTGRES_PORT=5432

# n8n
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=admin

# API
API_PORT=8000

# Web
WEB_PORT=3000

# LangChain (optional — needed for /ask endpoint)
ANTHROPIC_API_KEY=your-api-key-here

# CORS (comma-separated origins — include web container port for Docker)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# General
TIMEZONE=Europe/Madrid
